#include <stdio.h>

struct Process {
    char id[5];
    int arrival;
    int burst;
    int completion;
    int turnaround;
    int waiting;
};

int main()
{
    int n, i, j;
    printf("Enter number of processes: ");
    scanf("%d", &n);

    struct Process p[n];

 
    for (i = 0; i < n; i++)
        {
        printf("Enter ProcessID, ArrivalTime, BurstTime for process %d: ", i + 1);
        scanf("%s %d %d", p[i].id, &p[i].arrival, &p[i].burst);
        }

    
    for (i = 0; i < n - 1; i++)
        {
        for (j = 0; j < n - i - 1; j++)
        {
            if (p[j].arrival > p[j + 1].arrival)
             {
                struct Process temp = p[j];
                p[j] = p[j + 1];
                p[j + 1] = temp;
            }
        }
    }

    int current_time = 0;

     
    for (i = 0; i < n; i++) {
        if (current_time < p[i].arrival)
            {
            current_time = p[i].arrival; // CPU waits
            }
        p[i].completion = current_time + p[i].burst;
        p[i].turnaround = p[i].completion - p[i].arrival;
        p[i].waiting = p[i].turnaround - p[i].burst;
        current_time = p[i].completion;
    }

  
    printf("\nProcessID | Arrival | Burst | Completion | Turnaround | Waiting\n");
    for (i = 0; i < n; i++)
        {
        printf("%8s | %7d | %5d | %10d | %10d | %7d\n",
               p[i].id, p[i].arrival, p[i].burst,
               p[i].completion, p[i].turnaround, p[i].waiting);
        }

    return 0;
}


