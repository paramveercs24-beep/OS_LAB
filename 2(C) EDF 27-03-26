#include <stdio.h>

int main()
{
    int n;
    printf("Enter number of processes: ");
    scanf("%d", &n);

    int burst[n], period[n], remaining[n], deadline[n];

    printf("Enter burst times:\n");
    for (int i = 0; i < n; i++)
        scanf("%d", &burst[i]);

    printf("Enter periods:\n");
    for (int i = 0; i < n; i++)
        scanf("%d", &period[i]);

    int total_time = 20;

    for (int i = 0; i < n; i++)
    {
        remaining[i] = 0;
        deadline[i] = period[i];
    }

    printf("\nScheduling occurs for %d ms\n\n", total_time);

    for (int t = 0; t < total_time; t++)
    {
        for (int i = 0; i < n; i++)
        {
            if (t % period[i] == 0)
            {
                remaining[i] = burst[i];
                deadline[i] = t + period[i];
            }
        }

        int selected = -1;
        int min_deadline = 9999;

        for (int i = 0; i < n; i++)
        {
            if (remaining[i] > 0 && deadline[i] < min_deadline)
            {
                min_deadline = deadline[i];
                selected = i;
            }
        }

        if (selected == -1)
            printf("%dms: CPU is idle.\n", t);
        else
        {
            printf("%dms: Task %d is running.\n", t, selected + 1);
            remaining[selected]--;
        }
    }

    return 0;
}

