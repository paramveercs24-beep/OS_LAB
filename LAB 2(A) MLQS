 #include <stdio.h>

#define MAX 100

typedef struct {
    int pid;
    int at;
    int bt;
    int ct;
    int tat;
    int wt;
    int type;    
    int done;
} Process;

int main() {
    Process p[MAX];
    int n, i;
    int time = 0, completed = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

  
    for (i = 0; i < n; i++) {
        printf("\nProcess %d:\n", i + 1);

        p[i].pid = i + 1;

        printf("Arrival Time: ");
        scanf("%d", &p[i].at);

        printf("Burst Time: ");
        scanf("%d", &p[i].bt);

        printf("Type (0 = System, 1 = User): ");
        scanf("%d", &p[i].type);

        p[i].done = 0;
    }

 
    while (completed < n) {
        int idx = -1;

        
        for (i = 0; i < n; i++) {
            if (p[i].type == 0 && p[i].done == 0 && p[i].at <= time) {
                if (idx == -1 || p[i].at < p[idx].at) {
                    idx = i;
                }
            }
        }

      
        if (idx == -1) {
            for (i = 0; i < n; i++) {
                if (p[i].type == 1 && p[i].done == 0 && p[i].at <= time) {
                    if (idx == -1 || p[i].at < p[idx].at) {
                        idx = i;
                    }
                }
            }
        }

    
        if (idx == -1) {
            time++;
            continue;
        }

        
        time += p[idx].bt;
        p[idx].ct = time;
        p[idx].done = 1;
        completed++;
    }

     
    float total_tat = 0, total_wt = 0;

    printf("\nPID\tAT\tBT\tCT\tTAT\tWT\n");

    for (i = 0; i < n; i++) {
        p[i].tat = p[i].ct - p[i].at;
        p[i].wt = p[i].tat - p[i].bt;

        total_tat += p[i].tat;
        total_wt += p[i].wt;

        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].pid, p[i].at, p[i].bt,
               p[i].ct, p[i].tat, p[i].wt);
    }

    printf("\nAverage Turnaround Time = %.2f", total_tat / n);
    printf("\nAverage Waiting Time = %.2f\n", total_wt / n);

    return 0;
}

